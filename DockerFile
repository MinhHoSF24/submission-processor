# ─── STAGE 1: Builder ────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Leverage layer cache: only re-install when package*.json changes
COPY package*.json ./
RUN npm ci

# Copy all source then compile TypeScript → dist/
COPY tsconfig.json ./
COPY src/ ./src/
RUN npm run build

# ─── STAGE 2: Prune devDependencies ──────────────────────────────────────────
# Separate prune step to prevent layer cache from breaking when source code changes
FROM node:22-alpine AS deps

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

# ─── STAGE 3: Runtime (final image) ──────────────────────────────────────
FROM node:22-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production

# Run as 'node' user (not root) to reduce attack surface
USER node

# Only copy what's needed to run
COPY --chown=node:node package.json ./
COPY --chown=node:node --from=deps  /app/node_modules ./node_modules
COPY --chown=node:node --from=builder /app/dist       ./dist

# Expose port 3000
EXPOSE 3000
# Start the worker
CMD ["node", "dist/worker.js"]
