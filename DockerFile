# ─── STAGE 1: Builder ────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Tận dụng layer cache: chỉ re-install khi package*.json thay đổi
COPY package*.json ./
RUN npm ci

# Copy toàn bộ source rồi compile TypeScript → dist/
COPY tsconfig.json ./
COPY src/ ./src/
RUN npm run build

# ─── STAGE 2: Prune devDependencies ──────────────────────────────────────────
# Tách riêng bước prune để layer cache không bị vỡ khi source code thay đổi
FROM node:22-alpine AS deps

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

# ─── STAGE 3: Runtime (image cuối cùng) ──────────────────────────────────────
FROM node:22-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production

# Chạy dưới user 'node' (không phải root) để giảm attack surface
USER node

# Chỉ copy đúng những gì cần chạy
COPY --chown=node:node package.json ./
COPY --chown=node:node --from=deps  /app/node_modules ./node_modules
COPY --chown=node:node --from=builder /app/dist       ./dist

# Expose port 3000
EXPOSE 3000
# Chạy worker
CMD ["node", "dist/worker.js"]
