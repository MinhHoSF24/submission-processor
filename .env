AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=my-user-data-json-bucket
SQS_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/479897912900/user-info-queue
# When deploying: remove SQS_QUEUE_URL and use the SSM parameter name instead (value in SSM = queue URL)
# SQS_QUEUE_URL_PARAMETER=/my-app/sqs-queue-url
LOG_LEVEL=info

# ECR (for reference when pulling/pushing — dotenv does NOT expand ${VAR} in .env files)
ECR_REPO=submission-processor
IMAGE_TAG=749ef40
AWS_ACCOUNT_ID=479897912900
# Full URI example: 479897912900.dkr.ecr.ap-southeast-1.amazonaws.com/submission-processor:749ef40

# (Optional) AWS profile when running Docker locally with mounted ~/.aws — defaults to "default"
# AWS_PROFILE=default
