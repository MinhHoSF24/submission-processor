{
  "rules": [
      {
          "rulePriority": 1,
          "description": "Remove untagged images after 7 days",
          "selection": {
              "tagStatus": "untagged",
              "countType": "sinceImagePushed",
              "countUnit": "days",
              "countNumber": 7
          },
          "action": {
              "type": "expire"
          }
      },
      {
          "rulePriority": 2,
          "description": "Keep only the 10 most recent images with tags",
          "selection": {
              "tagStatus": "any",
              "countType": "imageCountMoreThan",
              "countNumber": 10
          },
          "action": {
              "type": "expire"
          }
      }
  ]
}